generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ShowcaseEntry {
  id             String         @id
  name           String
  url            String
  description    String?
  createdAt      DateTime       @default(now())
  approvalStatus ApprovalStatus @default(IDLE)
  screenshot     String?
}

enum ApprovalStatus {
  IDLE
  APPROVED
  REJECTED
}

enum DocsFeedbackValue {
  positive
  negative
}

model OrmFeedback {
  id          BigInt             @id @default(autoincrement())
  value       DocsFeedbackValue
  comment     String?
  title       String?
  description String?
  url         String
  pathname    String
  path        String
  entry       String
  slug        String
  locale      String?
  userAgent   String?            @map("userAgent")
  createdAt   DateTime           @default(now()) @map("createdAt")

  @@index([createdAt], map: "ormFeedback_createdAt_idx")
  @@index([slug], map: "ormFeedback_slug_idx")
  @@map("ormFeedback")
}
