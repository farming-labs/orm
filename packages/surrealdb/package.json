{
  "name": "@farming-labs/orm-surrealdb",
  "version": "0.0.52",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsx ./scripts/build.ts",
    "test": "vitest run --config vitest.local.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@farming-labs/orm": "workspace:*"
  },
  "devDependencies": {
    "@surrealdb/node": "^3.0.3",
    "surrealdb": "^2.0.3",
    "tsup": "^8.4.0"
  },
  "peerDependencies": {
    "surrealdb": "^2.0.3"
  }
}
