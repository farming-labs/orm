{
  "name": "@farming-labs/orm-xata",
  "version": "0.0.58",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsx ./scripts/build.ts",
    "test": "vitest run --config vitest.local.config.ts",
    "test:real": "tsx ./scripts/test-real.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@farming-labs/orm": "workspace:*",
    "@farming-labs/orm-sql": "workspace:*"
  },
  "devDependencies": {
    "@types/pg": "^8.15.6",
    "@xata.io/client": "^0.30.1",
    "pg": "^8.16.3",
    "tsup": "^8.4.0"
  },
  "peerDependencies": {
    "@xata.io/client": "^0.30.1"
  }
}
